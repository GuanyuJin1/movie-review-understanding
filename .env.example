# OpenAI API configuration (optional)
# Never commit a real API key. Create a local .env file for private credentials.
OPENAI_API_KEY=your_openai_api_key_here

# Optional LLM backend controls
# Supported values: auto, ollama, openai
# LLM_BACKEND=auto

# Ollama local backend settings
# OLLAMA_MODEL=qwen2.5:7b
# OLLAMA_BASE_URL=http://localhost:11434/v1

# OpenAI cloud backend setting
# OPENAI_MODEL=gpt-5.4-mini
